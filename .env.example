# =============================================================
# JobHunter - Environment Variables
# =============================================================
# Copy this file to ".env" and fill in your values.
# Lines starting with # are comments and are ignored.
# =============================================================

# --- REQUIRED ---

# --- GEMINI API KEYS (Dual-Key Architecture) ---
# FREE key: high-volume, low-stakes tasks (batch pipeline classification, URL scraping)
GEMINI_FREE_API_KEY=your_free_key_here

# PAID key: high-quality, user-facing tasks (bot conversations, cover letters, CV generation)
GEMINI_PAID_API_KEY=your_paid_key_here

# Legacy fallback (still works if you only have one key)
GEMINI_API_KEYS=your_key_here

# Telegram Bot Token (create via @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram Chat ID (send /start to your bot, then use @userinfobot to get your ID)
TELEGRAM_CHAT_ID=your_chat_id_here

# --- OPTIONAL ---

# RapidAPI key for JSearch - free tier at https://rapidapi.com/
# RAPIDAPI_KEY=
