# =============================================================
# JobHunter - Environment Variables
# =============================================================
# Copy this file to ".env" and fill in your values.
# Lines starting with # are comments and are ignored.
# =============================================================

# Which Ollama model to use (run: ollama pull llama3.1)
OLLAMA_MODEL=llama3.1

# (Optional) Adzuna API - free tier, get keys at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# (Optional) RapidAPI key for JSearch - free tier at https://rapidapi.com/
RAPIDAPI_KEY=

# Path to your Obsidian vault (example: C:\Users\you\MyVault)
OBSIDIAN_VAULT_PATH=
